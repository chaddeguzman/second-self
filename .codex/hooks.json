{
  "description": "Protect Second Self private-data operations.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/90-system/automation/hooks/pre_tool_use.py\"",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; python (Join-Path $root '90-system/automation/hooks/pre_tool_use.py')\"",
            "timeout": 10,
            "statusMessage": "Checking Second Self edit policy"
          }
        ]
      }
    ]
  }
}
